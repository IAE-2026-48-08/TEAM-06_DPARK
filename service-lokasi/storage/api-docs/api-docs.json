    "paths": {
        "/api/v1/locations": {
            "get": {
                "tags": [
                    "Locations"
                ],
                "summary": "Get all parking locations with real-time empty slots",
                "operationId": "49873ce3b7837cc865db7849ec7cccda",
                "responses": {
                    "200": {
                        "description": "Successful operation",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "array",
                                    "items": {
                                        "properties": {
                                            "id": {
                                                "type": "integer",
                                                "example": 1
                                            },
                                            "name": {
                                                "type": "string",
                                                "example": "DPARK Braga"
                                            },
                                            "address": {
                                                "type": "string",
                                                "example": "Jl. Braga No. 5 Bandung"
                                            },
                                            "capacity_car": {
                                                "type": "integer",
                                                "example": 40
                                            },
                                            "capacity_motor": {
                                                "type": "integer",
                                                "example": 80
                                            },
                                            "occupied_car": {
                                                "type": "integer",
                                                "example": 32
                                            },
                                            "occupied_motor": {
                                                "type": "integer",
                                                "example": 45
                                            },
                                            "available_car_slots": {
                                                "type": "integer",
                                                "example": 8
                                            },
                                            "available_motor_slots": {
                                                "type": "integer",
                                                "example": 35
                                            },
                                            "tariff_car": {
                                                "type": "string",
                                                "example": "5000.00"
                                            },
                                            "tariff_motor": {
                                                "type": "string",
                                                "example": "2000.00"
                                            },
                                            "operating_hours": {
                                                "type": "string",
                                                "example": "06:00 - 23:00"
                                            }
                                        },
                                        "type": "object"
                                    }
                                }
                            }
                        }
                    }
                }
            },
            "post": {
                "tags": [
                    "Locations"
                ],
                "summary": "Add a new parking location (Admin)",
                "operationId": "aff6a55f233e5e2483ad2a6b68576fbb",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "address",
                                    "capacity_car",
                                    "capacity_motor",
                                    "tariff_car",
                                    "tariff_motor",
                                    "operating_hours"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "DPARK Pasteur"
                                    },
                                    "address": {
                                        "type": "string",
                                        "example": "Jl. Pasteur No. 12 Bandung"
                                    },
                                    "capacity_car": {
                                        "type": "integer",
                                        "example": 30
                                    },
                                    "capacity_motor": {
                                        "type": "integer",
                                        "example": 60
                                    },
                                    "tariff_car": {
                                        "type": "number",
                                        "format": "float",
                                        "example": 5000
                                    },
                                    "tariff_motor": {
                                        "type": "number",
                                        "format": "float",
                                        "example": 2000
                                    },
                                    "operating_hours": {
                                        "type": "string",
                                        "example": "06:00 - 23:00"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Location created successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": true
                                        },
                                        "data": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Validation error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": false
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Validation errors occurred"
                                        },
                                        "errors": {
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "success": {
                                            "type": "boolean",
                                            "example": false
                                        },
                                        "message": {
                                            "type": "string",
                                            "example": "Unauthorized: Invalid or missing X-API-KEY"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "ApiKeyAuth": []
                    }
                ]
            }
        },
