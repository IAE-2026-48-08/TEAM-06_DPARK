                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successful operation",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "id": {
                                            "type": "integer",
                                            "example": 1
                                        },
                                        "name": {
                                            "type": "string",
                                            "example": "DPARK Braga"
                                        },
                                        "address": {
                                            "type": "string",
                                            "example": "Jl. Braga No. 5 Bandung"
                                        },
                                        "capacity_car": {
                                            "type": "integer",
                                            "example": 40
                                        },
                                        "capacity_motor": {
                                            "type": "integer",
                                            "example": 80
                                        },
                                        "occupied_car": {
                                            "type": "integer",
                                            "example": 32
                                        },
                                        "occupied_motor": {
                                            "type": "integer",
                                            "example": 45
                                        },
                                        "available_car_slots": {
                                            "type": "integer",
                                            "example": 8
                                        },
                                        "available_motor_slots": {
                                            "type": "integer",
